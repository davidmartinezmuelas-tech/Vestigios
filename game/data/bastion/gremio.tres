[gd_resource type="Resource" script_class="FacilityData" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/bastion/facility_data.gd" id="1"]

[resource]
script = ExtResource("1")
facility_id = "gremio"
display_name = "Gremio"
description = "El personaje es Maestro de Gremio de unos 50 miembros. Elige el tipo de gremio. Los miembros pueden realizar misiones especiales por encargo: rastrear bestias, construir muros, fabricar barcos, robar objetos o suministrar bienes."
required_bastion_level = 4
prerequisite_flag = "has_expertise"
space = 2
hireling_count = 1
available_orders = [3, 6]
build_cost = 10000
build_missions = 3
order_options = [
	{"id": "asignacion_gremial", "order": 3, "name": "Asignación gremial", "description": "Los miembros del gremio realizan la tarea específica del tipo de gremio elegido. El resultado depende del tipo: Gremio de Aventureros (rastrear bestia CR≤2), Constructores (muro defensivo gratis), Ladrones (robar objeto en 50km), etc."},
]
