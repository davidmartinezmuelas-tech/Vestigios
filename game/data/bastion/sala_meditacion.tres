[ext_resource type="Script" path="res://scripts/bastion/facility_data.gd" id="1"]

[resource]
script = ExtResource("1")
facility_id = "sala_meditacion"
display_name = "Sala de Meditación"
description = "Espacio relajante para alinear mente, cuerpo y espíritu. Permite mejorar el resultado de eventos del Bastión y otorgar ventaja en tiradas de salvación tras meditación prolongada."
required_bastion_level = 3
prerequisite_flag = ""
space = 0
hireling_count = 1
available_orders = [2, 6]
build_cost = 2000
build_missions = 1
order_options = [
	{"id": "paz_interior", "order": 2, "name": "Paz interior", "description": "La próxima vez que se tire en la tabla de Eventos del Bastión, se puede tirar dos veces y elegir el resultado."},
	{"id": "fortalecerse", "order": 2, "name": "Fortalecerse", "description": "7 días de meditación sin salir del Bastión. Al terminar: ventaja en 2 tipos de tiradas de salvación aleatorias durante 7 días."},
]
