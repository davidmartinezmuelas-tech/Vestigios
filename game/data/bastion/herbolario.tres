	{"id": "veneno", "order": 1, "name": "Cosechar veneno", "description": "1 veneno básico o 2 viales de Antitoxina. Gratis. Tarda 1 misión."},
	{"id": "pocion_mayor", "order": 1, "name": "Poción de Curación (mayor)", "description": "Requiere Bastión nivel 2+. 1 Poción de Curación Mayor. Tarda 1 misión.", "requires_bastion_level": 2},
