[ext_resource type="Script" path="res://scripts/bastion/facility_data.gd" id="1"]

[resource]
script = ExtResource("1")
facility_id = "circulo_teleportacion"
display_name = "Círculo de Teletransportación"
description = "Un círculo de teletransportación permanente inscrito en el suelo. Permite reclutar hechiceros visitantes que pueden lanzar conjuros de nivel 4 o inferior bajo petición."
required_bastion_level = 2
prerequisite_flag = ""
space = 1
hireling_count = 1
available_orders = [3, 6]
build_cost = 3000
build_missions = 2
order_options = [
	{"id": "reclutar_hechicero", "order": 3, "name": "Invitar hechicero", "description": "El hireling invita a un hechicero aliado. Tirar un dado: par = acepta y llega por el círculo. Puede lanzar 1 conjuro de nivel 4 o inferior mientras estés en el Bastión. Se va en 14 días o tras lanzar el conjuro."},
]
