[gd_scene load_steps=6 format=3]

[ext_resource type="Script" path="res://scripts/combat/combat_manager.gd" id="1"]
[ext_resource type="Script" path="res://scripts/combat/turn_manager.gd" id="2"]
[ext_resource type="Script" path="res://scripts/combat/combat_resolver.gd" id="3"]
[ext_resource type="Script" path="res://scripts/combat/combat_grid.gd" id="4"]
[ext_resource type="Script" path="res://scripts/ui/combat_ui.gd" id="5"]

[node name="CombatScene" type="Node2D"]

; ── LÓGICA ────────────────────────────────────────────────────
[node name="CombatManager" type="Node" parent="."]
script = ExtResource("1")

[node name="TurnManager" type="Node" parent="CombatManager"]
script = ExtResource("2")

[node name="CombatResolver" type="Node" parent="CombatManager"]
script = ExtResource("3")

[node name="CombatGrid" type="Node" parent="CombatManager"]
script = ExtResource("4")
grid_width = 20
grid_height = 12

; ── MAPA ──────────────────────────────────────────────────────
[node name="Map" type="Node2D" parent="."]

[node name="Floor" type="ColorRect" parent="Map"]
color = Color(0.10, 0.09, 0.08, 1.0)
size = Vector2(1920, 1080)
position = Vector2(0, 0)

; ── PERSONAJES ────────────────────────────────────────────────
[node name="Characters" type="Node2D" parent="."]

[node name="HeroParty" type="Node2D" parent="Characters"]
position = Vector2(320, 440)

[node name="EnemyGroup" type="Node2D" parent="Characters"]
position = Vector2(960, 440)

[node name="EffectLayer" type="Node2D" parent="."]

; ── UI ────────────────────────────────────────────────────────
[node name="CombatUI" type="CanvasLayer" parent="." script=ExtResource("5")]
layer = 5

; PARTY (izquierda)
[node name="PartyPanel" type="VBoxContainer" parent="CombatUI"]
anchor_bottom = 1.0
offset_right = 220.0
offset_top = 60.0
offset_bottom = -160.0
offset_left = 12.0
theme_override_constants/separation = 6

; ORDEN DE TURNO (arriba centro)
[node name="TurnOrderBar" type="HBoxContainer" parent="CombatUI"]
anchor_left = 0.2
anchor_right = 0.8
offset_bottom = 50.0
theme_override_constants/separation = 4

; BARRA DE HABILIDADES (abajo)
[node name="AbilityBar" type="HBoxContainer" parent="CombatUI"]
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = -110.0
offset_left = 8.0
offset_right = -8.0
theme_override_constants/separation = 8
visible = false

[node name="ActiveName" type="Label" parent="CombatUI/AbilityBar"]
custom_minimum_size = Vector2(100, 0)
vertical_alignment = 1
text = "—"
theme_override_font_sizes/font_size = 13

[node name="Abilities" type="HBoxContainer" parent="CombatUI/AbilityBar"]
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="Separator" type="VSeparator" parent="CombatUI/AbilityBar"]

[node name="MoveButton" type="Button" parent="CombatUI/AbilityBar"]
custom_minimum_size = Vector2(110, 52)
text = "Mover"

[node name="EndTurnButton" type="Button" parent="CombatUI/AbilityBar"]
custom_minimum_size = Vector2(110, 52)
text = "Fin de turno"
