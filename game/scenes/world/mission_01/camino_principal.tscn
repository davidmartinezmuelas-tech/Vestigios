[node name="CombatResolver" type="Node" parent="CombatManager"]

[node name="CombatGrid" type="Node" parent="CombatManager"]

; ── PERSONAJES (spawnea por código) ─────────────────────────
[node name="Characters" type="Node2D" parent="."]

