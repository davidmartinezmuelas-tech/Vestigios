size = Vector2(1920, 1080)

; Camino
[node name="Road" type="ColorRect" parent="."]
color = Color(0.18, 0.15, 0.12, 1.0)
size = Vector2(1920, 200)
position = Vector2(0, 440)

; ── TEXTO NARRATIVO ──────────────────────────────────────────
[node name="RoadLabel" type="Label" parent="."]
anchor_left = 0.1
anchor_right = 0.9
offset_top = 40.0
offset_bottom = 100.0
text = "El camino principal. La luna llena os ilumina — y os hace visibles."
