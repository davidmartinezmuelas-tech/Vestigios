func _add_sprite(x: int, y: int, sort_y: int, tex_path: String) -> void:
	var s := Sprite2D.new()
	s.texture = load(tex_path)
	s.position = Vector2(x, y)
	s.offset = Vector2(0, -192)
	s.z_index = sort_y
	add_child(s)
	s.owner = get_tree().edited_scene_root if Engine.is_editor_hint() else null