func _add_sprite(x: int, y: int, depth: int, tex_path: String, sc: float, off_y: int) -> void:
	var s := Sprite2D.new()
	s.texture = load(tex_path)
	s.position = Vector2(x, y)
	s.scale = Vector2(sc, sc)
	s.offset = Vector2(0, off_y)
	s.z_index = depth
	# Nearest neighbor: mantiene la nitidez pixel art sin blur
	s.texture_filter = CanvasItem.TEXTURE_FILTER_NEAREST
	add_child(s)
	s.owner = get_tree().edited_scene_root if Engine.is_editor_hint() else null